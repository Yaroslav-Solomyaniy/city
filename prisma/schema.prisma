datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "./src/generated/prisma"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Токен запрошення для реєстрації нового адміністратора
model InviteToken {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  email     String
  used      Boolean  @default(false)
  expires   DateTime
  createdBy String // userId того хто запросив

  createdAt DateTime @default(now())
}
